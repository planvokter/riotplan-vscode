{
  "name": "riotplan-vscode",
  "displayName": "RiotPlan",
  "description": "Plan management for RiotPlan HTTP server",
  "version": "1.0.12-dev.0",
  "publisher": "kjerneverk",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:riotplan.debugServerAuth",
    "onCommand:riotplan.transferPlan",
    "onCommand:riotplan.openServerManager",
    "onCommand:riotplan.addServerConnection",
    "onCommand:riotplan.switchServerConnection",
    "onCommand:riotplan.showServerConnectionDetails",
    "onCommand:riotplan.removeServerConnection",
    "onCommand:riotplan.configureApiKey",
    "onCommand:riotplan.clearApiKey",
    "onCommand:riotplan.syncContextCatalog"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "RiotPlan",
      "properties": {
        "riotplan.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3002",
          "description": "Legacy single-server fallback URL. Prefer riotplan.serverProfiles.",
          "markdownDescription": "Active RiotPlan HTTP MCP server URL (legacy/single-server fallback). For multi-server setups, use `riotplan.serverProfiles` and [Manage Servers and Tokens](command:riotplan.openServerManager)."
        },
        "riotplan.serverProfiles": {
          "type": "array",
          "default": [],
          "description": "Configured RiotPlan server profiles.",
          "markdownDescription": "List of RiotPlan server profiles. Use Settings UI to add items with the `+` button, or use [Add Server Connection](command:riotplan.addServerConnection). Configure per-server API tokens in [Manage Servers and Tokens](command:riotplan.openServerManager).",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "url",
              "enabled"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable profile identifier"
              },
              "name": {
                "type": "string",
                "description": "Display name for this server profile"
              },
              "url": {
                "type": "string",
                "description": "RiotPlan HTTP MCP server URL"
              },
              "enabled": {
                "type": "boolean",
                "description": "Whether this profile is enabled for startup connections"
              },
              "proxyBypass": {
                "type": "boolean",
                "description": "Bypass proxy for this server profile"
              },
              "createdAt": {
                "type": "string"
              },
              "updatedAt": {
                "type": "string"
              }
            }
          }
        },
        "riotplan.activeServerId": {
          "type": "string",
          "default": "",
          "description": "Active RiotPlan server profile id.",
          "markdownDescription": "ID of the active server profile in `riotplan.serverProfiles`. You can change this via [Manage Servers and Tokens](command:riotplan.openServerManager)."
        },
        "riotplan.proxyBypass": {
          "type": "boolean",
          "default": false,
          "description": "Global fallback proxy bypass. Prefer per-profile proxyBypass in riotplan.serverProfiles."
        },
        "riotplan.debugAuthLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose request logging for token/auth header debugging (redacted values).",
          "markdownDescription": "When enabled, logs each RiotPlan HTTP/SSE request with redacted auth-header presence to the `RiotPlan Auth Debug` output channel."
        },
        "riotplan.contextCatalogReplication": {
          "type": "boolean",
          "default": true,
          "description": "Replicate context project entities across all connected MCP servers (UUID catalog, merge on connect, upsert all-to-all).",
          "markdownDescription": "When enabled, new context projects created in the extension are **upserted to every connected server** (UUID from `crypto.randomUUID()`, stamped with `catalogUpdatedAt` / `catalogRevision`). On connect / manual sync, the extension merges by **newer `catalogUpdatedAt` first**, then higher `catalogRevision`, and upserts the merged catalog everywhere. Edits made only via MCP on one server are picked up on the next merge/sync, not pushed live by the extension (the project detail view is read-only). Disable for fully independent servers."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "riotplan",
          "title": "RiotPlan",
          "icon": "media/riotplan-icon.svg"
        }
      ]
    },
    "views": {
      "riotplan": [
        {
          "id": "riotplan-plans",
          "name": "Plans"
        },
        {
          "id": "riotplan-projects",
          "name": "Projects"
        },
        {
          "id": "riotplan-connection",
          "name": "Connection Status"
        }
      ]
    },
    "commands": [
      {
        "command": "riotplan.refreshPlans",
        "title": "Refresh Plans",
        "icon": "$(refresh)"
      },
      {
        "command": "riotplan.openPlanFiltersMenu",
        "title": "Filter Plans…",
        "icon": "$(filter)"
      },
      {
        "command": "riotplan.filterPlansByProject",
        "title": "Filter by Project",
        "icon": "$(folder)"
      },
      {
        "command": "riotplan.filterPlansByStatus",
        "title": "Filter by Status",
        "icon": "$(list-filter)"
      },
      {
        "command": "riotplan.addPlan",
        "title": "Add New Plan",
        "icon": "$(add)"
      },
      {
        "command": "riotplan.sortPlans",
        "title": "Sort Plans",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "riotplan.uploadPlan",
        "title": "Upload Plan",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "riotplan.downloadPlan",
        "title": "Download Plan",
        "icon": "$(cloud-download)"
      },
      {
        "command": "riotplan.transferPlan",
        "title": "Transfer Plan to Server",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "riotplan.openPlan",
        "title": "Open Plan"
      },
      {
        "command": "riotplan.openPlanDetails",
        "title": "Open Details",
        "icon": "$(preview)"
      },
      {
        "command": "riotplan.configureServerUrl",
        "title": "Configure Server URL",
        "icon": "$(gear)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.openServerManager",
        "title": "Manage Servers and Tokens",
        "icon": "$(settings-gear)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.addServerConnection",
        "title": "Add Server Connection",
        "icon": "$(add)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.switchServerConnection",
        "title": "Switch Server Connection",
        "icon": "$(server-process)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.showServerConnectionDetails",
        "title": "Show Server Connection Details",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.removeServerConnection",
        "title": "Remove Server Connection",
        "icon": "$(trash)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.configureApiKey",
        "title": "Configure API Token",
        "icon": "$(key)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.clearApiKey",
        "title": "Clear API Token",
        "icon": "$(trash)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.debugServerAuth",
        "title": "Debug Server Auth Headers",
        "icon": "$(bug)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.reconnect",
        "title": "Reconnect",
        "icon": "$(plug)"
      },
      {
        "command": "riotplan.syncContextCatalog",
        "title": "Sync Context",
        "icon": "$(repo-sync)",
        "category": "RiotPlan"
      },
      {
        "command": "riotplan.openDashboard",
        "title": "Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "riotplan.copyPlanUrl",
        "title": "Copy Plan URL",
        "icon": "$(link-external)"
      },
      {
        "command": "riotplan.changePlanProject",
        "title": "Change Project",
        "icon": "$(repo)"
      },
      {
        "command": "riotplan.openProjectEntity",
        "title": "Open Project Details",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "riotplan.deletePlan",
        "title": "Delete Plan",
        "icon": "$(trash)"
      },
      {
        "command": "riotplan.renamePlan",
        "title": "Rename Plan",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "riotplan.openDashboard",
          "when": "view == riotplan-plans",
          "group": "navigation"
        },
        {
          "command": "riotplan.refreshPlans",
          "when": "view == riotplan-projects",
          "group": "navigation"
        },
        {
          "command": "riotplan.syncContextCatalog",
          "when": "view == riotplan-projects && config.riotplan.contextCatalogReplication",
          "group": "navigation"
        },
        {
          "command": "riotplan.refreshPlans",
          "when": "view == riotplan-plans",
          "group": "navigation"
        },
        {
          "command": "riotplan.syncContextCatalog",
          "when": "view == riotplan-plans && config.riotplan.contextCatalogReplication",
          "group": "navigation"
        },
        {
          "command": "riotplan.openPlanFiltersMenu",
          "when": "view == riotplan-plans",
          "group": "navigation"
        },
        {
          "command": "riotplan.addPlan",
          "when": "view == riotplan-plans",
          "group": "navigation"
        },
        {
          "command": "riotplan.sortPlans",
          "when": "view == riotplan-plans",
          "group": "navigation"
        },
        {
          "command": "riotplan.uploadPlan",
          "when": "view == riotplan-plans",
          "group": "navigation"
        },
        {
          "command": "riotplan.configureServerUrl",
          "when": "view == riotplan-connection",
          "group": "navigation"
        },
        {
          "command": "riotplan.openServerManager",
          "when": "view == riotplan-connection",
          "group": "navigation"
        },
        {
          "command": "riotplan.addServerConnection",
          "when": "view == riotplan-connection",
          "group": "navigation"
        },
        {
          "command": "riotplan.switchServerConnection",
          "when": "view == riotplan-connection",
          "group": "navigation"
        },
        {
          "command": "riotplan.reconnect",
          "when": "view == riotplan-connection",
          "group": "navigation"
        },
        {
          "command": "riotplan.debugServerAuth",
          "when": "view == riotplan-connection",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "riotplan.openPlanDetails",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "navigation@1"
        },
        {
          "command": "riotplan.copyPlanUrl",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "navigation@2"
        },
        {
          "command": "riotplan.changePlanProject",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "navigation@3"
        },
        {
          "command": "riotplan.openProjectEntity",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "navigation@4"
        },
        {
          "command": "riotplan.downloadPlan",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "navigation@5"
        },
        {
          "command": "riotplan.transferPlan",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "navigation@6"
        },
        {
          "command": "riotplan.renamePlan",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "navigation@7"
        },
        {
          "command": "riotplan.deletePlan",
          "when": "view == riotplan-plans && viewItem == plan",
          "group": "danger@1"
        },
        {
          "command": "riotplan.openProjectEntity",
          "when": "view == riotplan-projects && viewItem == project",
          "group": "navigation@1"
        },
        {
          "command": "riotplan.syncContextCatalog",
          "when": "view == riotplan-projects && viewItem == project && config.riotplan.contextCatalogReplication",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "clean": "rm -rf dist out",
    "build": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src",
    "test": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "precommit": "npm run build && npm run lint && npm run coverage",
    "prepublishOnly": "npm run clean && npm run build",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.28.0",
    "@types/node": "^24.10.9",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/planvokter/riotplan-vscode"
  },
  "license": "Apache-2.0",
  "author": "Tim O'Brien <tobrien@discursive.com>",
  "dependencies": {
    "https-proxy-agent": "^7.0.6"
  },
  "publishConfig": {
    "tag": "dev"
  }
}
